# Inicializando a biblioteca
Ncm.cfg_init()

# Escolhendo o modelo
cosmo = Nc.HICosmoDEXcdm()

#Reparametrização.
cosmo.omega_x2omega_k()
#Universo plano
cosmo.param_set_by_name("Omegak", 0.0)

#Escolhendo quais parâmetros entraão no processo de inferência
cosmo.props.H0_fit = True
cosmo.props.Omegab_fit = False
cosmo.props.Omegac_fit = True
cosmo.props.w_fit = True

#Incializando o dist e definindo o redshift de optmização
dist = Nc.Distance(zf=3.0)


# Definindo o modelo astrofísico de supernova
snia_idval = Nc.DataSNIAId.COV_PANTHEON_PLUS_SH0ES_SYS_STAT
print(snia_idval)
snia_model = Nc.SNIADistCov.new_by_id(dist, snia_idval)
snia_model.props.M1_fit = True
#snia_model.props.alpha = 0.148
#snia_model.props.beta =  3.09

# Definindo o modelo a ser usado no processo de Restrição
mset = Ncm.MSet()
mset.set(cosmo)
mset.set(snia_model)

snia = Nc.DataSNIACov.new_from_cat_id(snia_idval, False)

# Definindo qual amostra será utilizada
dset = Ncm.Dataset()
dset.append_data(snia)

# Definindo outra parte da Hipótese
lh = Ncm.Likelihood(dataset=dset)

#>======================================================<#
#                  Ajuste frequêntista.
#>======================================================<#


# Definindo os aspectos do Fit, método de encontrar máximos e mínimos, qual likelihood está sendo empregada, modelo, método de cálculo de derivada. 
fit = Ncm.Fit.factory(
    Ncm.FitType.NLOPT, "ln-neldermead", lh, mset, Ncm.FitGradType.NUMDIFF_FORWARD
)

fit.run_restart(Ncm.FitRunMsgs.SIMPLE, 1.0e-3, 0.0, None, None)

fit.log_info()

#Calculando a matriz de covariância e a matriz de correlação.
fit.fisher()

fit.log_covar()

'''
# Parte computacionalmente pesada
# dedicada a comparação de regiões
'''
lhr2dcw = Ncm.LHRatio2d.new(fit,mset.fparam_get_pi_by_name("Omegac"),mset.fparam_get_pi_by_name("w"),1.0e-2)
best_w1 = cosmo.props.w
best_Omegac1 = cosmo.props.Omegac

regiaocw = lhr2dcw.fisher_border(Ncm.C.stats_1sigma(), 50.0, Ncm.FitRunMsgs.SIMPLE)
Omegac_a = np.array(regiaocw.p1.dup_array())
w_a = np.array(regiaocw.p2.dup_array())

regiaocw2 = lhr2dcw.conf_region(Ncm.C.stats_1sigma(), 50.0, Ncm.FitRunMsgs.SIMPLE)
Omegac_a2 = np.array(regiaocw2.p1.dup_array())
w_a2 = np.array(regiaocw2.p2.dup_array())
'''
'''

#>======================================================<#
#                          MCMC
#>======================================================<#

#
# Definindo Kernel, proposal covariance matrix e priors
#
kernel = Ncm.MSetTransKernGauss.new(0)
kernel.set_mset(mset)
# Escolhendo priors uniformes do modelo
kernel.set_prior_from_mset()
# Usando a matriz de covariância obtida anteriomente
kernel.set_cov(fit.get_covar())


#Aqui é interessante perceber que o código utiliza uma estimativa frequenista gerar um fit e uma matriz de covariância
#para serem usados na abordagem Bayesiana.

#
# MCMC
# Definindo os parâmetros do algoritmo, ponto inicial, distribuição de exploração que serão colocados no algoritmo.
mcmc = Ncm.FitMCMC.new(
    fit,
    kernel,
    Ncm.FitRunMsgs.SIMPLE
)

#Criando o arquivo que contém a cadeia
mcmc.set_data_file("MCMC3")

mcmc.start_run()
'''
# Se você quiser realizar testes no código
''
